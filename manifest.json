{
  "manifest_version": 3,
  "name": "AI Context Translator",
  "version": "1.0.0",
  "description": "Automatic AI-powered webpage translation for Firefox using Pollinations with BYOK support.",
  "permissions": ["storage", "activeTab", "scripting"],
  "host_permissions": ["<all_urls>", "https://gen.pollinations.ai/*"],
  "background": {
    "scripts": ["background.js"]
  },
  "action": {
    "default_popup": "popup.html",
    "default_title": "AI Context Translator"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content-script.js"],
      "run_at": "document_idle"
    }
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "ai-context-translator@example.com",
      "strict_min_version": "109.0"
    }
  }
}
